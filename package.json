{
  "name": "sopockie-laweczki",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:admin": "npm run dev -w apps/web-admin",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build -w apps/web",
    "build:admin": "npm run build -w apps/web-admin",
    "test:api": "npm run test -w apps/api",
    "preview": "npm run preview -w apps/web",
    "preview:admin": "npm run preview -w apps/web-admin"
  },
  "devDependencies": {
    "@babel/core": "7.28.5"
  },
  "overrides": {
    "@babel/core": {
      ".": "7.28.5",
      "@babel/generator": "7.28.5",
      "@babel/parser": "7.28.5",
      "@babel/template": "7.27.2",
      "@babel/traverse": "7.28.5",
      "@babel/types": "7.28.5"
    }
  }
}
